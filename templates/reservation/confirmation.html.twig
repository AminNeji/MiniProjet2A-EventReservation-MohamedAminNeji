{% extends 'base.html.twig' %}
{% block title %}Réservation confirmée !{% endblock %}

{% block body %}
<div class="confirmation-page">
    <div class="confirmation-card">
        <div class="confirm-icon">✅</div>
        <h1>Réservation confirmée !</h1>
        <p class="confirm-subtitle">Votre place est réservée avec succès.</p>

        <div class="confirm-details">
            <div class="confirm-row">
                <span class="confirm-label">Événement</span>
                <span class="confirm-value">{{ event.title }}</span>
            </div>
            <div class="confirm-row">
                <span class="confirm-label">Date</span>
                <span class="confirm-value">{{ event.date|date('d M Y à H:i') }}</span>
            </div>
            <div class="confirm-row">
                <span class="confirm-label">Lieu</span>
                <span class="confirm-value">{{ event.location }}</span>
            </div>
            <div class="confirm-row">
                <span class="confirm-label">Nom</span>
                <span class="confirm-value">{{ reservation.name }}</span>
            </div>
            <div class="confirm-row">
                <span class="confirm-label">Email</span>
                <span class="confirm-value">{{ reservation.email }}</span>
            </div>
            <div class="confirm-row">
                <span class="confirm-label">Téléphone</span>
                <span class="confirm-value">{{ reservation.phone }}</span>
            </div>
            <div class="confirm-row">
                <span class="confirm-label">Réservé le</span>
                <span class="confirm-value">{{ reservation.createdAt|date('d M Y à H:i') }}</span>
            </div>
        </div>

        <div class="confirm-actions">
            <a href="{{ path('app_event_index') }}" class="btn-primary">Voir d'autres événements</a>
            <a href="{{ path('app_home') }}" class="btn-secondary">Accueil</a>
        </div>
    </div>
</div>
{% endblock %}
