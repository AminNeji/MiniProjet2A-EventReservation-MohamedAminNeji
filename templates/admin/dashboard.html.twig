{% extends 'admin/base_admin.html.twig' %}
{% block title %}Dashboard{% endblock %}
{% block page_title %}Dashboard{% endblock %}

{% block topbar_actions %}
    <a href="{{ path('admin_event_new') }}" class="btn-admin-primary">+ Nouvel événement</a>
{% endblock %}

{% block body %}
<div class="stats-grid">
    <div class="stat-card stat-blue">
        <div class="stat-card-num">{{ totalEvents }}</div>
        <div class="stat-card-lbl">Événements</div>
    </div>
    <div class="stat-card stat-green">
        <div class="stat-card-num">{{ totalReservations }}</div>
        <div class="stat-card-lbl">Réservations totales</div>
    </div>
    <div class="stat-card stat-orange">
        <div class="stat-card-num">{{ events|filter(e => e.isFull)|length }}</div>
        <div class="stat-card-lbl">Événements complets</div>
    </div>
    <div class="stat-card stat-purple">
        <div class="stat-card-num">{{ events|filter(e => e.date >= date())|length }}</div>
        <div class="stat-card-lbl">À venir</div>
    </div>
</div>

<div class="admin-section">
    <div class="admin-section-header">
        <h3>Événements récents</h3>
        <a href="{{ path('admin_events') }}">Voir tout →</a>
    </div>

    <table class="admin-table">
        <thead>
            <tr>
                <th>Titre</th>
                <th>Date</th>
                <th>Lieu</th>
                <th>Places</th>
                <th>Réservations</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
        {% for event in events|slice(0, 8) %}
            <tr>
                <td><strong>{{ event.title }}</strong></td>
                <td>{{ event.date|date('d/m/Y H:i') }}</td>
                <td>{{ event.location }}</td>
                <td>{{ event.seats }}</td>
                <td>
                    <span class="{{ event.isFull ? 'badge-full' : 'badge-open' }}">
                        {{ event.reservations|length }} / {{ event.seats }}
                    </span>
                </td>
                <td class="action-btns">
                    <a href="{{ path('admin_event_reservations', {id: event.id}) }}" class="btn-sm btn-blue">📋</a>
                    <a href="{{ path('admin_event_edit', {id: event.id}) }}" class="btn-sm btn-orange">✏️</a>
                </td>
            </tr>
        {% else %}
            <tr><td colspan="6" class="empty-row">Aucun événement</td></tr>
        {% endfor %}
        </tbody>
    </table>
</div>
{% endblock %}
