{% extends 'base.html.twig' %}
{% block title %}Événements{% endblock %}

{% block body %}
<div class="page-header">
    <h1>Tous les événements</h1>
    <p>{{ events|length }} événement(s) disponible(s)</p>
</div>

{% if events|length > 0 %}
<div class="events-grid">
    {% for event in events %}
    <article class="event-card">
        <div class="event-card-img">
            {% if event.image %}
                <img src="{{ asset('uploads/events/' ~ event.image) }}" alt="{{ event.title }}">
            {% else %}
                <div class="event-img-placeholder">◈</div>
            {% endif %}
            {% if event.isFull %}
                <span class="badge-full">Complet</span>
            {% else %}
                <span class="badge-open">{{ event.availableSeats }} places</span>
            {% endif %}
        </div>
        <div class="event-card-body">
            <div class="event-date">{{ event.date|date('d M Y · H:i') }}</div>
            <h3 class="event-title">{{ event.title }}</h3>
            <p class="event-location">📍 {{ event.location }}</p>
            <p class="event-desc">{{ event.description|slice(0, 100) }}{% if event.description|length > 100 %}…{% endif %}</p>
            <a href="{{ path('app_event_show', {id: event.id}) }}" class="btn-card">Voir détails</a>
        </div>
    </article>
    {% endfor %}
</div>
{% else %}
<div class="empty-state">
    <div class="empty-icon">🗓️</div>
    <p>Aucun événement disponible pour le moment.</p>
</div>
{% endif %}
{% endblock %}
